#!/usr/bin/env bash
set -e

# Retirer docreader des associations MIME par défaut
REAL_USER="${SUDO_USER:-$USER}"
if [ -n "$REAL_USER" ] && [ "$REAL_USER" != "root" ]; then
    MIMEAPPS="$(getent passwd "$REAL_USER" | cut -d: -f6)/.config/mimeapps.list"
    if [ -f "$MIMEAPPS" ]; then
        sed -i '/docreader\.desktop/d' "$MIMEAPPS"
    fi
fi
